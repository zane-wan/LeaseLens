{
  "info": {
    "name": "LeaseLens Auth",
    "description": "Auth API test collection for LeaseLens. Covers signup, login, logout, and session verification with success and error scenarios.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:3000",
      "type": "string"
    }
  ],
  "item": [
    {
      "name": "Signup",
      "item": [
        {
          "name": "1. Signup — success (with name)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\",\n  \"name\": \"Test User\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Expected: 201 with user object. Sets token cookie."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('Returns user object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user).to.have.property('id');",
                  "  pm.expect(json.user.email).to.eql('test@example.com');",
                  "  pm.expect(json.user.name).to.eql('Test User');",
                  "});",
                  "pm.test('Sets token cookie', () => {",
                  "  const cookie = pm.response.headers.get('Set-Cookie');",
                  "  pm.expect(cookie).to.include('token=');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "2. Signup — success (without name)",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"noname@example.com\",\n  \"password\": \"test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Expected: 201. Name is optional."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201', () => pm.response.to.have.status(201));",
                  "pm.test('User name is null', () => {",
                  "  pm.expect(pm.response.json().user.name).to.be.null;",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "3. Signup — error: invalid email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"not-an-email\",\n  \"password\": \"test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Expected: 400. Invalid email format."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Returns error', () => {",
                  "  pm.expect(pm.response.json()).to.have.property('error');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "4. Signup — error: short password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"short@example.com\",\n  \"password\": \"123\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Expected: 400. Password must be at least 8 characters."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400', () => pm.response.to.have.status(400));",
                  "pm.test('Error mentions password', () => {",
                  "  pm.expect(pm.response.json().error).to.include('8');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "5. Signup — error: duplicate email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\",\n  \"name\": \"Duplicate\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/signup",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "signup"]
            },
            "description": "Expected: 409. Run after request #1 to trigger duplicate."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 409', () => pm.response.to.have.status(409));",
                  "pm.test('Error says already registered', () => {",
                  "  pm.expect(pm.response.json().error).to.include('already');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Login",
      "item": [
        {
          "name": "6. Login — success",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Expected: 200. Run after signup #1."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns user object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user).to.have.property('id');",
                  "  pm.expect(json.user.email).to.eql('test@example.com');",
                  "});",
                  "pm.test('Sets token cookie', () => {",
                  "  const cookie = pm.response.headers.get('Set-Cookie');",
                  "  pm.expect(cookie).to.include('token=');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "7. Login — error: wrong password",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"test@example.com\",\n  \"password\": \"wrongpassword\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Expected: 401. Same generic error as non-existent email."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Generic error message', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Invalid email or password');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "8. Login — error: non-existent email",
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "body": {
              "mode": "raw",
              "raw": "{\n  \"email\": \"nobody@example.com\",\n  \"password\": \"test1234\"\n}"
            },
            "url": {
              "raw": "{{baseUrl}}/api/auth/login",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "login"]
            },
            "description": "Expected: 401. Same error as wrong password (no user enumeration)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));",
                  "pm.test('Generic error message', () => {",
                  "  pm.expect(pm.response.json().error).to.eql('Invalid email or password');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Session",
      "item": [
        {
          "name": "9. Me — success (authenticated)",
          "request": {
            "method": "GET",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Expected: 200. Run after a successful login/signup (cookie is auto-sent)."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns user object', () => {",
                  "  const json = pm.response.json();",
                  "  pm.expect(json.user).to.have.property('id');",
                  "  pm.expect(json.user).to.have.property('email');",
                  "});"
                ]
              }
            }
          ]
        },
        {
          "name": "10. Me — error: not authenticated",
          "request": {
            "method": "GET",
            "header": [
              { "key": "Cookie", "value": "", "description": "Override cookie to simulate logged-out state" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/auth/me",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "me"]
            },
            "description": "Expected: 401. Clear cookies in Postman cookie jar before running, or run after logout."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 401', () => pm.response.to.have.status(401));"
                ]
              }
            }
          ]
        }
      ]
    },
    {
      "name": "Logout",
      "item": [
        {
          "name": "11. Logout — success",
          "request": {
            "method": "POST",
            "header": [],
            "url": {
              "raw": "{{baseUrl}}/api/auth/logout",
              "host": ["{{baseUrl}}"],
              "path": ["api", "auth", "logout"]
            },
            "description": "Expected: 200. Clears token cookie. Run Me after this to confirm 401."
          },
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200', () => pm.response.to.have.status(200));",
                  "pm.test('Returns logged out message', () => {",
                  "  pm.expect(pm.response.json().message).to.eql('Logged out');",
                  "});",
                  "pm.test('Clears token cookie', () => {",
                  "  const cookie = pm.response.headers.get('Set-Cookie');",
                  "  pm.expect(cookie).to.include('token=');",
                  "  pm.expect(cookie).to.include('Max-Age=0');",
                  "});"
                ]
              }
            }
          ]
        }
      ]
    }
  ]
}
