generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  image         String?
  role          UserRole  @default(USER)
  passwordHash  String?
  emailVerified Boolean   @default(false)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  accounts       Account[]
  sessions       Session[]
  agreements     Agreement[]
  supportThreads SupportThread[]
  supportMessages SupportMessage[]
  chatSessions   ChatSession[]
  chatMessages   ChatMessage[]
  memoryItems    MemoryItem[]
}

model Account {
  id                   String    @id @default(cuid())
  userId               String
  accountId            String
  providerId           String
  accessToken          String?
  refreshToken         String?
  accessTokenExpiresAt DateTime?
  scope                String?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
}

model Session {
  id        String   @id @default(cuid())
  userId    String
  token     String   @unique
  expiresAt DateTime
  ipAddress String?
  userAgent String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model Verification {
  id         String   @id @default(cuid())
  identifier String
  value      String
  expiresAt  DateTime
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model Agreement {
  id         String          @id @default(cuid())
  userId     String
  fileName   String
  s3Key      String          @unique
  s3Url      String?
  status     AgreementStatus @default(PENDING)
  uploadedAt DateTime        @default(now())
  updatedAt  DateTime        @updatedAt

  user     User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  analysis Analysis?
  chatSessions ChatSession[]
  memoryItems  MemoryItem[]

  @@index([userId])
}

enum AgreementStatus {
  PENDING
  PROCESSING
  COMPLETED
  FAILED
}

model Analysis {
  id           String         @id @default(cuid())
  agreementId  String         @unique
  status       AnalysisStatus @default(QUEUED)
  errorMessage String?
  startedAt    DateTime?
  completedAt  DateTime?
  createdAt    DateTime       @default(now())
  updatedAt    DateTime       @updatedAt

  agreement     Agreement      @relation(fields: [agreementId], references: [id], onDelete: Cascade)
  clauseResults ClauseResult[]
}

enum AnalysisStatus {
  QUEUED
  PROCESSING
  COMPLETED
  FAILED
}

model ClauseResult {
  id           String          @id @default(cuid())
  analysisId   String
  clauseIndex  Int
  clauseTitle  String
  clauseText   String
  compliance   ComplianceLabel
  explanation  String
  rtaCitations String[]
  severity     Severity?
  createdAt    DateTime        @default(now())

  analysis Analysis @relation(fields: [analysisId], references: [id], onDelete: Cascade)

  @@unique([analysisId, clauseIndex])
  @@index([analysisId])
}

enum ComplianceLabel {
  COMPLIANT
  NON_COMPLIANT
  NEEDS_REVIEW
}

enum Severity {
  LOW
  MEDIUM
  HIGH
}

enum UserRole {
  OWNER
  ADMIN
  USER
}

model SupportThread {
  id          String              @id @default(cuid())
  ownerUserId String
  subject     String
  status      SupportThreadStatus @default(OPEN)
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt

  owner    User             @relation(fields: [ownerUserId], references: [id], onDelete: Cascade)
  messages SupportMessage[]

  @@index([ownerUserId])
}

model SupportMessage {
  id             String         @id @default(cuid())
  threadId       String
  senderUserId   String
  senderRole     UserRole
  direction      MessageDirection @default(INBOUND)
  recipientEmail String
  subject        String
  body           String
  createdAt      DateTime       @default(now())

  thread SupportThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation(fields: [senderUserId], references: [id], onDelete: Cascade)

  @@index([threadId])
  @@index([senderUserId])
}

model ChatSession {
  id          String   @id @default(cuid())
  userId      String
  agreementId String?
  title       String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user       User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  agreement  Agreement?   @relation(fields: [agreementId], references: [id], onDelete: SetNull)
  messages   ChatMessage[]
  memoryItems MemoryItem[]

  @@index([userId])
  @@index([agreementId])
}

model ChatMessage {
  id         String      @id @default(cuid())
  sessionId  String
  userId     String
  role       ChatRole
  content    String
  citations  String[]
  createdAt  DateTime    @default(now())

  session ChatSession @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  user    User        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([userId])
}

model MemoryItem {
  id          String      @id @default(cuid())
  userId      String
  sessionId   String?
  agreementId String?
  scope       MemoryScope
  summary     String
  createdAt   DateTime    @default(now())

  user      User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  session   ChatSession? @relation(fields: [sessionId], references: [id], onDelete: SetNull)
  agreement Agreement?   @relation(fields: [agreementId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([sessionId])
  @@index([agreementId])
}

enum SupportThreadStatus {
  OPEN
  CLOSED
}

enum MessageDirection {
  INBOUND
  OUTBOUND
}

enum ChatRole {
  SYSTEM
  USER
  ASSISTANT
}

enum MemoryScope {
  ACCOUNT
  AGREEMENT
  SESSION
}
